# --- OpenRouter (the only paid dependency) ---
# Get a key at https://openrouter.ai/keys  and paste it here.
OPENROUTER_API_KEY=

# Cheap, capable default. Swap to a ":free" model for a zero-cost demo, e.g.
#   meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_MODEL=google/gemini-2.5-flash-lite

# Optional, shown in OpenRouter's dashboard analytics.
APP_URL=http://localhost:3000
APP_NAME=TechMart Support Switchboard

# --- Storage ---
# SQLite file for sessions + conversation memory (no external DB needed to run).
DATABASE_URL=support.db

# Where the FAISS index / embeddings cache is written.
VECTORSTORE_DIR=vectorstore
